# ===========================================================
# Díaz Lara Backend — plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena los valores. NUNCA
# commits del `.env` real (está en .gitignore).
# ===========================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
LOG_LEVEL=info
LOG_FILE=logs/app.log

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=diazlara
DB_PASSWORD=change-me
DB_NAME=diazlara
DB_POOL_SIZE=10

# --- Auth ---
JWT_SECRET=change-me-to-a-32-char-random-value
JWT_EXPIRY=86400

# --- Google Calendar / Meet ---
# Service account JSON (una sola línea, escapando comillas si es necesario).
# El mismo service account impersona a Jessica y a Jazmin — solo necesitas UN
# JSON, con Domain-Wide Delegation autorizada en Google Workspace Admin.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Emails opcionales que se copian como asistentes extra en cada evento (CSV).
GOOGLE_MEET_EXTRA_ATTENDEES=

# --- Modo multi-cuenta (Jessica + Jazmin) ---
# JSON con las cuentas de Google Workspace que pueden ser organizadoras.
# Cada consultor_id (UUID de CONSULTORES) se mapea a exactamente UNA cuenta.
# El backend usa esto para saber en qué calendario crear el evento y qué
# usuario debe organizar el Meet.
#
# Ejemplo (rellena los UUIDs reales):
# GOOGLE_CALENDAR_ACCOUNTS=[{"key":"jessica","impersonateUser":"jessica.tapia@diegodiaz.mx","calendarId":"primary","consultorIds":["<UUID_JESSICA>"]},{"key":"jazmin","impersonateUser":"fiscalista@diegodiaz.mx","calendarId":"primary","consultorIds":["<UUID_JAZMIN>"]}]
GOOGLE_CALENDAR_ACCOUNTS=

# Si "true", rechaza intentos de agendar contra un consultor que no tenga
# cuenta configurada arriba. Recomendado en producción.
STRICT_CALENDAR_ACCOUNTS=false

# --- Compatibilidad hacia atrás (una sola cuenta) ---
# Se usan sólo si GOOGLE_CALENDAR_ACCOUNTS está vacío. Permite mantener el
# servidor operando con una única cuenta durante la migración.
GOOGLE_IMPERSONATE_USER=fiscalista@diegodiaz.mx
GOOGLE_CALENDAR_ID=primary

# --- Round robin (agenda orgánica) ---
# CSV de nombres o UUIDs. Solo estos consultores (o super_admin) pueden agendar
# leads orgánicos, aparte de los session holders con cuenta de calendario.
AGENDA_ROUND_ROBIN_CONSULTORES=daniela,jesus

# --- SMTP (email transaccional) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@diazlara.mx
SMTP_PASS=change-me
SMTP_FROM="DL Sistema" <no-reply@diazlara.mx>
SMTP_REPLY_TO=contacto@diazlara.mx

# --- WhatsApp (Whapi) ---
WHAPI_TOKEN=
WHAPI_URL=https://gate.whapi.cloud
WHAPI_WEBHOOK_SECRET=

# --- HubSpot (opcional) ---
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=
