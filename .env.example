# Application Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (Hostinger MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=diazlara
DB_POOL_SIZE=10

# JWT Authentication
JWT_SECRET=your_secret_key_here_minimum_32_characters_long
JWT_EXPIRY=86400

# Google Meet / Google Calendar
GOOGLE_SERVICE_ACCOUNT_JSON={}
GOOGLE_CALENDAR_ID=your_consultant_email@gmail.com

# SendGrid Email Service
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=citas@diazlara.mx
SENDGRID_FROM_NAME=Díaz Lara Consultores

# Twilio WhatsApp API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155552671
TWILIO_WEBHOOK_URL=https://api.diazlara.mx/api/webhooks/twilio

# HubSpot Integration
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUBSPOT_PORTAL_ID=12345678

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
